# =====================================================================
# NVISION — Exemplo de variáveis de ambiente
# Copie para `.env` e preencha. NUNCA comite o `.env` real.
#   cp .env.example .env
# =====================================================================

# --- Camada de LLM (provider decidido depois) -----------------------
# Valores aceitos: "anthropic" | "openai"
LLM_PROVIDER=anthropic
# Modelo usado quando LLM_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
# Modelo usado quando LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=

# --- Embeddings (RAG — Entregável 3) --------------------------------
# Ex.: text-embedding-3-large (OpenAI) ou NV-Embed-v2 (NVIDIA)
EMBEDDING_MODEL=text-embedding-3-large

# --- Reranking (Cohere — Entregável 3) ------------------------------
COHERE_API_KEY=

# --- Scraping (Entregável 1) ----------------------------------------
FIRECRAWL_API_KEY=

# --- PostgreSQL (dados estruturados de startups) --------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nvision
POSTGRES_USER=nvision
POSTGRES_PASSWORD=nvision
# URL completa usada pela aplicação
DATABASE_URL=postgresql://nvision:nvision@localhost:5432/nvision

# --- Qdrant (banco vetorial) ----------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- App ------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO
